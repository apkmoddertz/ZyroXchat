rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // 2. Channels Collection
    match /channels/{channelId} {
      allow read, write: if isSignedIn();
    }

    // 3. Channel Members Subcollection
    match /channels/{channelId}/members/{memberId} {
      allow read, write: if isSignedIn();
    }

    // 4. Messages subcollection
    match /channels/{channelId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    // Collection Group rule for 'members' to support user memberships query queries
    match /{path=**}/members/{memberId} {
      allow read, write: if isSignedIn();
    }
  }
}
